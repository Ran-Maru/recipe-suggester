{
  "name": "recipe-suggester",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev --host",
    "build": "tsc -b && vp build",
    "format": "vp fmt .",
    "lint": "vp lint .",
    "preview": "vp preview",
    "test:e2e": "playwright test",
    "test:e2e:trace": "playwright test --trace on",
    "test:e2e:ui": "playwright test --trace on --ui --ui-host 0.0.0.0",
    "test:e2e:report": "playwright show-report --host 0.0.0.0 --port 9323",
    "prepare": "vp config"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@playwright/test": "1.58.2",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "typescript": "~6.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "4.1.9"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": "11.6.2",
      "onFail": "download"
    }
  }
}
